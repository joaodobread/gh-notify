{
  "name": "github-notify",
  "private": true,
  "bin": "./dist/github-notify",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "dev": "bun run index.ts",
    "build": "bun build index.ts --compile --outfile dist/github-notify",
    "build:macos": "bun build index.ts --compile --outfile dist/github-notify-macos",
    "build:win": "bun build index.ts --compile --outfile dist/github-notify.exe",
    "typecheck": "bunx tsc --noEmit"
  }
}
